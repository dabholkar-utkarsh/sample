# Server
PORT=4000
NODE_ENV=development

# Database (Railway PostgreSQL plugin sets DATABASE_URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/exmple

# Redis (Railway Redis plugin sets REDIS_URL)
REDIS_URL=redis://localhost:6379

# Clerk (optional for local dev)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Anthropic (optional)
ANTHROPIC_API_KEY=

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Resend (optional)
RESEND_API_KEY=

# Frontends
NEXT_PUBLIC_API_URL=http://localhost:4000
