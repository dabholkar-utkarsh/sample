{
  "name": "exmple",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "pnpm --filter @repo/api start:prod",
    "lint": "turbo lint",
    "db:generate": "dotenv -e .env -- pnpm --filter @repo/database generate",
    "db:push": "dotenv -e .env -- pnpm --filter @repo/database db:push"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
